generator client {
  provider = "prisma-client-js"
}   

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  SUCCESS
  FAILED
}

model Order {
  id         Int         @id @default(autoincrement())
  userId     Int
  foodId     Int[]
  quantity   Int
  address    String
  phone      String
  paymentMethod String
  totalPrice Decimal     @db.Decimal(10, 2)
  status     OrderStatus @default(PENDING)
  createdAt  DateTime    @default(now())

  @@index([userId])
}
